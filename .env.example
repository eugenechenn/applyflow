LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=15000
LLM_BASE_URL=https://api.openai.com/v1
SESSION_COOKIE_NAME=applyflow_session
