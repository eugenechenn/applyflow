APPLYFLOW_DB_FILE=applyflow.sqlite
APPLYFLOW_DB_PROVIDER=sqlite
APPLYFLOW_RUNTIME=node
CLOUDFLARE_D1_BINDING=APPLYFLOW_DB
PUBLIC_APP_ORIGIN=http://localhost:3000
